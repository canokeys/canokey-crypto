+    MBEDTLS_MPI_CHK(mbedtls_mpi_add_mod(grp, &t1,   &P->X,   &P->Y));
+    MBEDTLS_MPI_CHK(mbedtls_mpi_add_mod(grp, &t2,   &Q->X,   &Q->Y));
